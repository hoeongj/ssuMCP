# Normalize line endings to LF in the repository; check out native per-platform.
* text=auto

# Source and config are LF in the repo
*.java text
*.kt text
*.gradle text
*.yml text
*.yaml text
*.json text
*.md text
*.properties text

# Windows batch scripts must stay CRLF
*.bat text eol=crlf
*.cmd text eol=crlf

# Gradle wrapper unix script must stay LF
gradlew text eol=lf

# Treat known binaries as binary
*.jar binary
*.png binary
*.jpg binary
*.ico binary
*.so binary
*.dll binary
