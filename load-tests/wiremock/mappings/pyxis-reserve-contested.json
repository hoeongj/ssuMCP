{
  "mappings": [
    {
      "name": "Pyxis reserve — contested seat 9999, first request wins",
      "priority": 1,
      "scenarioName": "contested-seat",
      "requiredScenarioState": "Started",
      "newScenarioState": "charged",
      "request": {
        "method": "POST",
        "urlPath": "/pyxis-api/1/api/seat-charges",
        "bodyPatterns": [
          { "matchesJsonPath": "$[?(@.seatId == 9999)]" }
        ]
      },
      "response": {
        "status": 200,
        "headers": { "Content-Type": "application/json;charset=UTF-8" },
        "jsonBody": {
          "success": true,
          "code": "success.charged",
          "message": "예약되었습니다.",
          "data": {
            "id": "{{randomValue length=9 type='NUMERIC'}}",
            "room": { "name": "오픈열람실(2F)" },
            "seat": { "code": "9999" },
            "beginTime": "{{now format='yyyy-MM-dd HH:mm'}}",
            "endTime": "{{now offset='4 hours' format='yyyy-MM-dd HH:mm'}}"
          }
        },
        "delayDistribution": { "type": "lognormal", "median": 250, "sigma": 0.4 }
      }
    },
    {
      "name": "Pyxis reserve — contested seat 9999, already charged",
      "priority": 1,
      "scenarioName": "contested-seat",
      "requiredScenarioState": "charged",
      "request": {
        "method": "POST",
        "urlPath": "/pyxis-api/1/api/seat-charges",
        "bodyPatterns": [
          { "matchesJsonPath": "$[?(@.seatId == 9999)]" }
        ]
      },
      "response": {
        "status": 200,
        "headers": { "Content-Type": "application/json;charset=UTF-8" },
        "jsonBody": {
          "success": false,
          "code": "warning.seat.alreadyCharged",
          "message": "이미 사용 중인 좌석입니다."
        },
        "delayDistribution": { "type": "lognormal", "median": 180, "sigma": 0.35 }
      }
    }
  ]
}
