# n8n 2.x uses built-in user management — set the owner account (email/password)
# in the UI on first launch (localhost-only demo). No basic-auth password here.
DISCORD_WEBHOOK_URL_NOTICE=https://discord.com/api/webhooks/YOUR_NOTICE_WEBHOOK_ID/YOUR_TOKEN
DISCORD_WEBHOOK_URL_WEEKLY=https://discord.com/api/webhooks/YOUR_WEEKLY_WEBHOOK_ID/YOUR_TOKEN
SSUAI_API_BASE=https://ssumcp.duckdns.org
